# ── AI Model (Google Gemini Flash 2.0) ───────────────────────────────────────
# Free tier: 15 req/min, 1,500 req/day, 1M token context — no credit card needed
# Get your key at: aistudio.google.com → Get API Key
GEMINI_API_KEY=AIza...

# Optional overrides
# MODEL_PROVIDER=gemini     # gemini | groq | together | openrouter (default: gemini)
# MODEL_NAME=gemini-2.5-flash

# ── Gmail API ────────────────────────────────────────────────────────────────
# Run 'python gmail_auth.py' once locally to generate gmail_token.json
# For Railway: paste the full contents of gmail_token.json here
GMAIL_TOKEN_JSON={"token":"...","refresh_token":"...","token_uri":"..."}

# Gmail label to watch — create in Gmail + apply via filter rules
GMAIL_LABEL=Newsletters

# OR specify exact sender addresses instead of a label (comma-separated):
# GMAIL_SENDERS=editor@netinterest.co,brew@morningbrew.com

# How many days back to look on each poll (default: 1)
GMAIL_DAYS_BACK=1

# ── Database ─────────────────────────────────────────────────────────────────
# Local dev: leave as default (creates briefly.db in project root)
# Railway:   /data/briefly.db  (Railway Volume mounted at /data)
DB_PATH=briefly.db

# ── Data Retention ───────────────────────────────────────────────────────────
# How many days of newsletters, articles, and themes to keep in the database.
# Older data is automatically purged at the end of each daily pipeline run.
# Minimum recommended: 14. Default: 30.
DATA_RETENTION_DAYS=30

# ── Flask ────────────────────────────────────────────────────────────────────
PORT=5001
FLASK_DEBUG=1    # set to 0 in production / Railway
