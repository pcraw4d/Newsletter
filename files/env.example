# Briefly — environment variables
# Copy to .env for local dev. Set these in Railway dashboard for production.

# ── AI Model (Groq — free tier, no credit card needed) ──────────────────────
# Get your key at: console.groq.com
GROQ_API_KEY=gsk_...

# Optional: switch provider without code changes
# MODEL_PROVIDER=groq          # groq | together | openrouter (default: groq)
# MODEL_NAME=llama-3.3-70b-versatile  # override model name if needed

# ── Email Webhook (SendGrid) ─────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Set the same value in SendGrid dashboard → Inbound Parse → Custom Headers
WEBHOOK_SECRET=your_random_secret_here

# ── Database ─────────────────────────────────────────────────────────────────
# Local dev: leave as default (creates briefly.db in project root)
# Railway:   set to /data/briefly.db  (Railway Volume mounted at /data)
DB_PATH=briefly.db

# ── Flask ────────────────────────────────────────────────────────────────────
PORT=5001
FLASK_DEBUG=1    # set to 0 in production
